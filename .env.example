# ===== LLM 分析引擎（OpenAI 兼容接口）=====
# 留空 OPENAI_API_KEY 时，系统自动使用本地 Mock 分析器跑通流程
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== 数据存储目录（dataset 以 JSON 文件落盘，零原生依赖）=====
DATA_DIR=.data

# ===== 服务端口 =====
PORT=3000

# ===== 关闭 WebUI 自动关闭服务 =====
# true  : 启用（Windows 一键启动 start-dev.bat 默认设为 true）
# false : 关闭（普通 npm run dev 默认，避免开发调试意外退出）
# 不设置时默认 false
AUTO_SHUTDOWN_ENABLED=false
